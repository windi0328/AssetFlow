<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AssetFlow EMS</title>
    
    <!-- Google Fonts: Outfit & Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Icons: Bootstrap Icons (Lucide-like style) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-container">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <a class="brand-text text-decoration-none" asp-page="/Index">
                    <i class="bi bi-box-seam-fill text-primary"></i>
                    AssetFlow <span class="brand-badge">EMS</span>
                </a>
            </div>
            
            <nav class="nav-menu">
                <a class="nav-item @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")" asp-page="/Index">
                    <i class="bi bi-columns-gap"></i>
                    <span>控制台</span>
                </a>
                <a class="nav-item" href="#">
                    <i class="bi bi-database"></i>
                    <span>設備清單</span>
                </a>
                <a class="nav-item" href="#">
                    <i class="bi bi-arrow-down-up"></i>
                    <span>借用流程</span>
                </a>
                <a class="nav-item @(ViewContext.RouteData.Values["page"]?.ToString() == "/Privacy" ? "active" : "")" asp-page="/Privacy">
                    <i class="bi bi-info-circle"></i>
                    <span>專案說明</span>
                </a>
                
                <div class="mt-auto mb-4 px-3">
                    <div class="panel p-3 mb-0" style="background: rgba(255,255,255,0.03); border-radius: 12px; margin-bottom: 0;">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <div class="rounded-circle bg-primary p-1" style="width: 8px; height: 8px;"></div>
                            <span class="small text-muted fw-500">系統狀態</span>
                        </div>
                        <div class="small fw-bold">運行中 (v1.0.4)</div>
                    </div>
                </div>
            </nav>
        </aside>

        <!-- Main Content Wrapper -->
        <main class="main-content">
            <!-- Top Header Section (Mobile or Info) -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="mb-0">@ViewData["Title"]</h1>
                    <div class="text-muted small">歡迎回來，系統已載入最新資產數據</div>
                </div>
                <div class="d-flex gap-3 align-items-center">
                    <div class="panel p-2 mb-0 d-flex align-items-center gap-2" style="border-radius: 99px; padding: 0.5rem 1rem !important;">
                        <i class="bi bi-person-circle text-primary"></i>
                        <span class="fw-600 small me-2">Administrator</span>
                    </div>
                </div>
            </div>

            @RenderBody()

            <footer class="mt-5 pt-4 border-top border-secondary opacity-25">
                <div class="small">
                    &copy; 2026 AssetFlow EMS - Built with Premium Design System
                </div>
            </footer>
        </main>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
